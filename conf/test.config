/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Test profile — uses minimal data bundled in test/
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Minimal resource requirements
    max_cpus   = 4
    max_memory = '8.GB'
    max_time   = '2.h'

    // Input data
    samplesheet  = "${projectDir}/test/samplesheet.csv"
    genome       = "${projectDir}/test/data/genome.fa"
    intervals    = "${projectDir}/test/data/targets.bed"
    dbsnp        = "${projectDir}/test/data/dbsnp.vcf.gz"
    known_indels = "${projectDir}/test/data/known_indels.vcf.gz"
    vep_cache    = "${projectDir}/test/data/vep_cache"
}
