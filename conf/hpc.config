/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    HPC profile — SLURM executor
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    max_memory = '256.GB'
    max_cpus   = 32
    max_time   = '720.h'
}

process {
    executor     = 'slurm'
    queue        = 'normal'
    clusterOptions = '--account=<your-account>'
}

executor {
    queueSize    = 50
    submitRateLimit = '10/1min'
}
