/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    wes-pipeline Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

// ── Global defaults ──────────────────────────────────────────────────────────────────
params {
    // Input / Output
    samplesheet   = null
    outdir        = 'results'

    // Reference genome (GRCh38 recommended)
    genome        = null
    intervals     = null          // BED file with exome capture regions

    // GATK resources (GATK bundle)
    dbsnp         = null          // dbSNP VCF
    known_indels  = null          // Mills_and_1000G_gold_standard.indels VCF

    // VEP annotation
    vep_cache     = null          // Path to VEP cache directory
    vep_species   = 'homo_sapiens'
    vep_assembly  = 'GRCh38'

    // Resource defaults
    max_memory    = '128.GB'
    max_cpus      = 16
    max_time      = '240.h'

    // MultiQC
    multiqc_config = null
}

// ── Process defaults ─────────────────────────────────────────────────────────────────
process {
    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2
    maxErrors     = '-1'

    // Default resources
    cpus   = { check_max(2    * task.attempt, 'cpus')   }
    memory = { check_max(8.GB * task.attempt, 'memory') }
    time   = { check_max(4.h  * task.attempt, 'time')   }

    // Per-process resource overrides
    withName: 'BWA_MEM2_MEM' {
        cpus   = { check_max(12, 'cpus') }
        memory = { check_max(32.GB * task.attempt, 'memory') }
        time   = { check_max(24.h  * task.attempt, 'time') }
    }

    withName: 'MARKDUPLICATES' {
        cpus   = { check_max(4, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
    }

    withName: 'BASERECALIBRATOR|APPLYBQSR' {
        cpus   = { check_max(4, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
    }

    withName: 'HAPLOTYPECALLER' {
        cpus   = { check_max(4, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time   = { check_max(48.h  * task.attempt, 'time') }
    }

    withName: 'GENOTYPEGVCFS' {
        memory = { check_max(16.GB * task.attempt, 'memory') }
    }

    withName: 'VEP' {
        cpus   = { check_max(8, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
    }
}

// ── Docker ───────────────────────────────────────────────────────────────────────────
docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

// ── Profiles ─────────────────────────────────────────────────────────────────────────
profiles {
    debug   { process.beforeScript = 'echo $HOSTNAME' }
    test    { includeConfig 'conf/test.config' }
    hpc     { includeConfig 'conf/hpc.config' }
    cloud   { includeConfig 'conf/cloud.config' }
}

// ── Manifest ─────────────────────────────────────────────────────────────────────────
manifest {
    name            = 'wes-pipeline'
    author          = '<your-name>'
    homePage        = 'https://github.com/<your-username>/wes-pipeline'
    description     = 'Whole Exome Sequencing variant calling pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}

// ── Helper function ──────────────────────────────────────────────────────────────────
def check_max(obj, type) {
    if (type == 'memory') {
        try { return obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1 ? params.max_memory as nextflow.util.MemoryUnit : obj }
        catch (all) { println "WARNING: Max memory '${params.max_memory}' is not valid. Using default value: $obj"; return obj }
    } else if (type == 'time') {
        try { return obj.compareTo(params.max_time as nextflow.util.Duration) == 1 ? params.max_time as nextflow.util.Duration : obj }
        catch (all) { println "WARNING: Max time '${params.max_time}' is not valid. Using default value: $obj"; return obj }
    } else if (type == 'cpus') {
        try { return Math.min(obj, params.max_cpus as int) }
        catch (all) { println "WARNING: Max cpus '${params.max_cpus}' is not valid. Using default value: $obj"; return obj }
    }
}
